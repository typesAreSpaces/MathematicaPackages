        ",", 
        RowBox[{"Darker", "[", "Red", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "f"}], ",", 
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<- s_1 g\>\"", ",", "TeXForm", ",", "HoldForm"}], "]"}], 
        ",", 
        RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "-", "f"}], ",", 
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<1 - s_1 g\>\"", ",", "TeXForm", ",", "HoldForm"}], 
         "]"}], ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], "}"}], ",", 
    "intervals", ",", 
    RowBox[{
     RowBox[{"\"\<Interval:(\>\"", "<>", 
      RowBox[{"ToString", "[", "#1", "]"}], "<>", "\"\<, \>\"", "<>", 
      RowBox[{"ToString", "[", "#2", "]"}], "<>", "\"\<)\>\""}], "&"}]}], 
