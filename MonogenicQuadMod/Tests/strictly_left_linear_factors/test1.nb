  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotIntervals", "[", 
   RowBox[{"f_", ",", "intervals_"}], "]"}], ":=", 
  RowBox[{"PlotGrid", "[", 
   RowBox[{"x", ",", 
    RowBox[{"{", 
