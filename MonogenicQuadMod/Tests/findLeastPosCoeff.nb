Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"findLeastPosCoeff", "[", 
   RowBox[{"a_", ",", "p_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"roots", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}], "&"}], ",", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", "-", "a"}], ")"}], "+", "p"}], "\[Equal]", "0"}], 
          ",", "x"}], "]"}]}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"negativeRoots", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"roots", ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Im", "[", "#", "]"}], "\[Equal]", "0"}], "&&", 
            RowBox[{
             RowBox[{"Re", "[", "#", "]"}], "<", "a"}]}], "&"}]}], "]"}]}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"negativeRoots", "\[Equal]", 
         RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Case", " ", "where", " ", "there", " ", "are", " ", "no", " ", 
          "negative", " ", "roots"}], "*)"}], "\[IndentingNewLine]", "None", 
        ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Case", " ", "where", " ", "there", " ", "are", " ", "negative", " ",
           "roots"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Block", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"factor", "=", 
            RowBox[{"Minimize", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"x", "-", "a"}], ")"}], "/", "p"}], ",", 
                RowBox[{
                 RowBox[{"Min", "[", "negativeRoots", "]"}], "<", "x", "<", 
                 RowBox[{"Max", "[", "negativeRoots", "]"}]}]}], "}"}], ",", 
              "x"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", "factor"}], 
         "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.886108843647645*^9, 3.886108865222871*^9}, {
  3.886108901924097*^9, 3.8861089437263613`*^9}, {3.886108981701489*^9, 
