      RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "20"}]}], "}"}], ",", 
    "x"}], "]"}], "//", "N"}], "\[IndentingNewLine]", 
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "+", "pp9"}], "<", "0"}], ",", "x"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "+", "pp9"}], "\[Equal]", "0"}], ",", "x"}], "]"}], "//", 
  "N"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{"pp9", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "15", ",", "20"}], "}"}], ",", 
