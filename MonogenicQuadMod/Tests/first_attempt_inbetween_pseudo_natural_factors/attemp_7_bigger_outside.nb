Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<DorisAlgorithmCompactCase`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.8922130831162777`*^9, 3.892213083685746*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"04a18523-6315-499b-8fb4-4d19718417f9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"infix", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "+", "2"}], ")"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "+", "1"}], ")"}], "^", "3"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"outfix", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "+", "3"}], ")"}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "-", "1"}], ")"}], "^", "3"}], 
   RowBox[{"(", 
    RowBox[{"x", "-", "2"}], ")"}], 
   RowBox[{"(", 
    RowBox[{"x", "-", "3"}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{
    RowBox[{"-", "outfix"}], " ", "infix"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"templateS1", "=", 
   RowBox[{
    RowBox[{"a", "^", "2"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "-", "b"}], ")"}], "^", "2"}], "+", 
      RowBox[{"c", "^", "2"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"DorisAlgorithmCompactCase", "[", 
  RowBox[{"x", ",", "infix", ",", 
   RowBox[{"{", "g", "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"-", "g"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "g"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "+", "3"}], ")"}], "/", "2"}]}], ")"}], "^", "2"}]}], 
   ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "g"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "+", "3"}], ")"}], "/", "2"}]}], ")"}], "^", "2"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "-", "3"}], ")"}], "/", "2"}]}], ")"}], "^", 
     "2"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}]}], "Input",
