Cell[BoxData[{
 RowBox[{
  RowBox[{"Needs", "[", "\"\<PlotGrid`\>\"", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotIntervals", "[", 
   RowBox[{"f_", ",", "a_", ",", "x_", ",", "intervals_"}], "]"}], ":=", 
  RowBox[{"PlotGrid", "[", 
   RowBox[{"x", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"f", ",", 
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<s_1 g_2\>\"", ",", "TeXForm", ",", "HoldForm"}], "]"}], 
        ",", 
        RowBox[{"Darker", "[", "Red", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "f"}], ",", 
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<- s_1 g_2\>\"", ",", "TeXForm", ",", "HoldForm"}], 
         "]"}], ",", 
        RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "a"}], ")"}], "-", "f"}], ",", 
        RowBox[{"ToExpression", "[", 
         RowBox[{
         "\"\<(X - a_1) - s_1 g\>\"", ",", "TeXForm", ",", "HoldForm"}], 
         "]"}], ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], "}"}], ",", 
    "intervals", ",", 
    RowBox[{
     RowBox[{"\"\<Interval:(\>\"", "<>", 
      RowBox[{"ToString", "[", "#1", "]"}], "<>", "\"\<, \>\"", "<>", 
      RowBox[{"ToString", "[", "#2", "]"}], "<>", "\"\<)\>\""}], "&"}]}], 
