          RowBox[{"(", 
           RowBox[{"9", "/", "5"}], ")"}]}], "+", "x"}], ")"}]}]}]}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"G", "=", 
         RowBox[{"{", 
          RowBox[{"gnat1", ",", "gnat2", ",", "gnat3", ",", "gnat4"}], 
          "}"}]}], ",", 
