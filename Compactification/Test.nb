Notebook[{
Cell[BoxData[{
 RowBox[{"Needs", "[", "\"\<Compactification`\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Needs", "[", "\"\<CauchyBounds`\>\"", "]"}]}], "Input",
 CellChangeTimes->{{3.979146436991308*^9, 3.979146446357298*^9}},
