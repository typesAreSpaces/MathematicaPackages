Cell[BoxData[
 RowBox[{
  RowBox[{"test", "[", 
   RowBox[{"f_", ",", "gens_", ",", "x_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "sigma", ",", "tau", ",", "h"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sigma", ",", "tau", ",", "h"}], "}"}], "=", 
      RowBox[{"compactification", "[", 
       RowBox[{"f", ",", "gens", ",", "x"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Semialgebraic set of generators: \>\"", ",", 
       RowBox[{"Reduce", "[", 
        RowBox[{
         RowBox[{"gens", ">=", "0"}], ",", "x"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Checking sigma is nonnegative: \>\"", ",", 
       RowBox[{"Reduce", "[", 
        RowBox[{
         RowBox[{"sigma", "<", "0"}], ",", "x"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Checking tau is nonnegative: \>\"", ",", 
       RowBox[{"Reduce", "[", 
        RowBox[{
         RowBox[{"tau", "<", "0"}], ",", "x"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Checking h is strictly positive over Semialg(gens): \>\"", ",", 
       RowBox[{"Reduce", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"gens", ">=", "0"}], "&&", 
          RowBox[{"h", "<=", "0"}]}], ",", "x"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Identity: \>\"", ",", 
       RowBox[{"Expand", "[", 
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"sigma", " ", "f"}], "+", 
          RowBox[{"tau", " ", "h"}]}], "]"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"sigma", ",", "tau", ",", "h"}], "}"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.978625682096195*^9, 3.978625682303293*^9}, {
