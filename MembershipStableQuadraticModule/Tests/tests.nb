Cell[BoxData[{
 RowBox[{"Needs", "[", "\"\<MembershipStableQuadraticModule`\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<PolyDegree`\>\"", "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TestMQM", "[", 
   RowBox[{
   "param_", ",", "poly_", ",", "G_List", ",", "boundFunction_", ",", "tol_", 
    ",", "maxite_", ",", "method_", ",", "enablePrint_"}], "]"}], ":=", "\n", 
  
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"result", "=", 
      RowBox[{
       RowBox[{"MembershipStableQM", "[", 
        RowBox[{
        "param", ",", "poly", ",", "G", ",", "boundFunction", ",", "tol", ",",
          "maxite", ",", "method"}], "]"}], "//", "Quiet"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"result", "===", "\"\<No Gram matrix found\>\""}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{
        "poly", ",", "\"\< does not belong to the QM of \>\"", ",", "G"}], 
        "]"}], ";", "\[IndentingNewLine]", "result"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{"enablePrint", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
          "Print", "[", 
           "\"\<--------------------------------------------------------------\
----\>\"", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"poly", ",", "\"\< belongs to the QM of \>\"", ",", "G"}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<The Gram matrix is \>\"", ",", " ", 
            RowBox[{
             RowBox[{"result", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "//", "MatrixForm"}]}], "]"}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<The representation found is \>\"", ",", " ", 
            RowBox[{"result", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Expand of representation found is \>\"", ",", " ", 
            RowBox[{"Expand", "[", 
             RowBox[{"result", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Original polynomial is \>\"", ",", "poly"}], "]"}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Expand of original polynomial is \>\"", ",", 
            RowBox[{"poly", "//", "Expand"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Generators are \>\"", ",", " ", "G"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{"\"\<SOS multipliers are: \>\"", ",", " ", 
             RowBox[{"result", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "//", "Simplify"}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{
          "Print", "[", 
           "\"\<--------------------------------------------------------------\
----\>\"", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"result", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\n", "]"}]}]}], "Input",
